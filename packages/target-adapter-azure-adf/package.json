{
  "name": "@databridge/target-adapter-azure-adf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase C1 — Azure Data Factory target adapter. Emits a deployable ADF pipeline JSON (Copy activity per entity) from buffered canonical rows; optional live execution via the management API uses a bearer token from @databridge/azure-auth. Dry-run / stub by default so CI stays hermetic.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/adapter-spec": "workspace:*",
    "@databridge/target-adapters": "workspace:*",
    "@databridge/azure-auth": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0"
  }
}
