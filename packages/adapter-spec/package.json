{
  "name": "@databridge/adapter-spec",
  "version": "0.1.0",
  "description": "SourceAdapter and TargetAdapter TypeScript interfaces for DataBridge connectors",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
