{
  "name": "@databridge/adapter-sits-oracle",
  "version": "0.1.0",
  "description": "Read adapter for Tribal SITS Oracle database (SITS:Vision and SITS:eSIS)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/platform": "workspace:*",
    "@databridge/adapter-spec": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "oracledb": "^6.4.0"
  },
  "peerDependenciesMeta": {
    "oracledb": {
      "optional": true
    }
  }
}
