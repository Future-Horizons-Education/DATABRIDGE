{
  "name": "@databridge/migration-banner-to-sits",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Migration orchestrator: Banner source (oracle or ethos) -> @databridge/canonical -> SITS-shaped load plan (emitted, not executed)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/platform": "workspace:*",
    "@databridge/adapter-spec": "workspace:*",
    "@databridge/adapter-banner-oracle": "workspace:*",
    "@databridge/adapter-banner-ethos": "workspace:*",
    "@databridge/codeset-mapper": "workspace:*",
    "@databridge/identity-reconciler": "workspace:*",
    "@databridge/profile-banner": "workspace:*",
    "@databridge/target-adapters": "workspace:*",
    "@databridge/parallel-run-verifier": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
