{
  "name": "@databridge/profile-banner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DataBridge profile for Ellucian Banner — entity map, canonical field catalogue, and the SPRIDEN/STVMAJR/STVCAMP/SHRTGPA programme/student/registration mapping used by Banner↔SITS migrations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/adapter-spec": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
